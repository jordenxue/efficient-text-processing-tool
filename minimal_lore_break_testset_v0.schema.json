{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "minimal_lore_break_testset_v0",
  "description": "Schema for the v0 starter split: Clean Canon cases are the main score pool, and Author-Conflict Register entries are diagnostic only.",
  "oneOf": [
    {
      "$ref": "#/definitions/clean_canon_case"
    },
    {
      "$ref": "#/definitions/author_conflict_case"
    }
  ],
  "definitions": {
    "clean_canon_case": {
      "type": "object",
      "required": [
        "case_id",
        "mode",
        "prompt",
        "target_type",
        "canon_fact",
        "expected_behavior",
        "scoring_mode",
        "severity",
        "notes"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "pattern": "^CC-[0-9]{3}$"
        },
        "mode": {
          "type": "string",
          "enum": [
            "continue_writing",
            "rewrite"
          ]
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "target_type": {
          "type": "string",
          "enum": [
            "character_fact",
            "naming_consistency"
          ]
        },
        "canon_fact": {
          "type": "string",
          "minLength": 1
        },
        "expected_behavior": {
          "type": "string",
          "minLength": 1
        },
        "scoring_mode": {
          "type": "string",
          "enum": [
            "main_score"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "author_conflict_case": {
      "type": "object",
      "required": [
        "conflict_id",
        "conflict_type",
        "evidence_a",
        "evidence_b",
        "current_status",
        "policy",
        "scoring_mode",
        "notes"
      ],
      "properties": {
        "conflict_id": {
          "type": "string",
          "pattern": "^AC-[0-9]{3}$"
        },
        "conflict_type": {
          "type": "string",
          "enum": [
            "character_fact_conflict",
            "naming_conflict"
          ]
        },
        "evidence_a": {
          "type": "string"
        },
        "evidence_b": {
          "type": "string"
        },
        "current_status": {
          "type": "string",
          "enum": [
            "unresolved"
          ]
        },
        "policy": {
          "type": "string",
          "enum": [
            "must_warn_and_negotiate"
          ]
        },
        "scoring_mode": {
          "type": "string",
          "enum": [
            "diagnostic_only"
          ]
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
